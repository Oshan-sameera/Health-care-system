{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["patient", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Doctor": {
      "title": "Doctor",
      "description": "Doctor profile information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "specialty": { "type": "string" },
        "experience": { "type": "number" },
        "about": { "type": "string" },
        "image": { "type": "string" },
        "department": { "type": "string" },
        "availableDays": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "name", "specialty", "department"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Appointment booking details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "patientName": { "type": "string" },
        "doctorId": { "type": "string" },
        "doctorName": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "time": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled", "completed"] },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientId", "doctorId", "date", "time", "status"]
    },
    "Report": {
      "title": "Report",
      "description": "Patient medical reports",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "title": { "type": "string" },
        "fileUrl": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientId", "title", "fileUrl", "date"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/doctors/{doctorId}": {
      "schema": "Doctor",
      "description": "Doctor profiles"
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Appointment records"
    },
    "/reports/{reportId}": {
      "schema": "Report",
      "description": "Patient reports"
    }
  }
}
